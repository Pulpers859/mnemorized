APP_ENV=development
HOST=127.0.0.1
PORT=8001
APP_BASE_URL=http://127.0.0.1:8001
ANTHROPIC_API_KEY=replace-with-local-anthropic-key
ANTHROPIC_MAX_TOKENS=8192
CORS_ORIGINS=*
TRUST_PROXY_HEADERS=false
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BYTES=12000000
USAGE_LOG_PATH=backend/logs/anthropic_usage.jsonl
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
SUPABASE_JWT_AUDIENCE=authenticated
ADMIN_EMAILS=admin@example.com
FREE_MONTHLY_REQUESTS=40
PRO_MONTHLY_REQUESTS=400
TEAM_MONTHLY_REQUESTS=4000
BILLING_MODE=beta
GEMINI_API_KEY=replace-with-local-gemini-key
GEMINI_MODEL=gemini-3-pro-image
GEMINI_TEXT_MODEL=gemini-3.1-pro-preview
GEMINI_IMAGE_MODEL=gemini-3-pro-image
OPENAI_API_KEY=replace-with-local-openai-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
